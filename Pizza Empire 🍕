<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>🍕 Pizza Empire</title>
<style>
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: 'Arial', sans-serif;
  background: linear-gradient(135deg, #ff6b6b, #feca57);
  color: #2d3436;
  padding: 20px;
  min-height: 100vh;
}

.container {
  max-width: 1200px;
  margin: 0 auto;
}

h1 {
  text-align: center;
  font-size: 48px;
  color: #fff;
  text-shadow: 3px 3px 6px rgba(0,0,0,0.3);
  margin-bottom: 20px;
}

.game-area {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  margin-bottom: 20px;
}

.stats {
  background: rgba(255,255,255,0.95);
  padding: 25px;
  border-radius: 15px;
  box-shadow: 0 8px 20px rgba(0,0,0,0.2);
}

.info-toggle {
  background: #3498db;
  color: white;
  border: none;
  padding: 10px 20px;
  border-radius: 8px;
  cursor: pointer;
  font-weight: bold;
  font-size: 16px;
  margin-bottom: 15px;
  transition: all 0.2s;
  width: 100%;
}

.info-toggle:hover {
  background: #2980b9;
  transform: translateY(-2px);
}

#statsContent {
  display: block;
}

#statsContent.hidden {
  display: none;
}

.stat-item {
  font-size: 24px;
  margin: 15px 0;
  font-weight: bold;
}

.money {
  color: #27ae60;
  font-size: 32px;
}

.cps {
  color: #e67e22;
  font-size: 20px;
}

.clicker-area {
  background: rgba(255,255,255,0.95);
  padding: 25px;
  border-radius: 15px;
  box-shadow: 0 8px 20px rgba(0,0,0,0.2);
  text-align: center;
}

.pizza-btn {
  background: transparent;
  color: white;
  border: 4px solid white;
  padding: 20px;
  font-size: 80px;
  border-radius: 50%;
  cursor: pointer;
  transition: transform 0.1s, box-shadow 0.1s;
  box-shadow: 0 6px 15px rgba(0,0,0,0.3);
  margin: 20px;
  width: 150px;
  height: 150px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.pizza-btn:hover {
  transform: scale(1.05);
  box-shadow: 0 0 30px rgba(255,255,255,0.6);
}

.pizza-btn:active {
  transform: scale(0.95);
  box-shadow: 0 3px 8px rgba(0,0,0,0.3);
}

.serve-btn {
  background: #3498db;
  color: white;
  border: none;
  padding: 15px 30px;
  font-size: 20px;
  border-radius: 10px;
  cursor: pointer;
  font-weight: bold;
  transition: all 0.2s;
  box-shadow: 0 4px 10px rgba(0,0,0,0.2);
  margin-top: 10px;
}

.serve-btn:hover {
  background: #2980b9;
  transform: translateY(-2px);
}

.serve-btn:active {
  transform: translateY(0);
}

.serve-btn:disabled {
  background: #95a5a6;
  cursor: not-allowed;
}

.upgrades {
  background: rgba(255,255,255,0.95);
  padding: 25px;
  border-radius: 15px;
  box-shadow: 0 8px 20px rgba(0,0,0,0.2);
}

.upgrades h2 {
  font-size: 28px;
  margin-bottom: 15px;
  color: #e74c3c;
  border-bottom: 3px solid #e74c3c;
  padding-bottom: 10px;
}

.upgrade-section {
  margin-bottom: 25px;
}

.upgrade-section h3 {
  font-size: 20px;
  margin-bottom: 10px;
  color: #2c3e50;
}

.upgrade-item {
  background: #f8f9fa;
  padding: 12px;
  margin: 8px 0;
  border-radius: 8px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border: 2px solid #dfe6e9;
}

.upgrade-item.owned {
  background: #d4edda;
  border-color: #27ae60;
}

.upgrade-info {
  flex: 1;
}

.upgrade-name {
  font-weight: bold;
  font-size: 16px;
}

.upgrade-desc {
  font-size: 12px;
  color: #636e72;
}

.upgrade-btn {
  background: #27ae60;
  color: white;
  border: none;
  padding: 10px 20px;
  border-radius: 8px;
  cursor: pointer;
  font-weight: bold;
  transition: all 0.2s;
}

.upgrade-btn:hover {
  background: #229954;
  transform: scale(1.05);
}

.upgrade-btn:disabled {
  background: #95a5a6;
  cursor: not-allowed;
}

@media (max-width: 768px) {
  .game-area {
    grid-template-columns: 1fr;
  }
}
</style>
</head>
<body>

<div class="container">
  <h1>🍕 Pizza Empire 🍕</h1>
  
  <div class="game-area">
    <div class="stats" id="statsPanel">
      <div class="stat-item money">💰 $<span id="money">0</span></div>
      <button class="info-toggle" onclick="toggleStats()">ℹ️ INFO</button>
      <div id="statsContent">
        <div class="stat-item">🍕 Pizzas Ready: <span id="pizzas">0</span></div>
        <div class="stat-item">💵 Pizza Value: $<span id="pizzaValue">1</span></div>
        <div class="stat-item cps">⚡ CPS: <span id="cps">0</span>/sec</div>
      </div>
    </div>
    
    <div class="clicker-area">
      <h2>Make Pizzas!</h2>
      <button class="pizza-btn" onclick="makePizza()">🍕</button>
      <div>
        <button class="serve-btn" id="serveBtn" onclick="servePizza()">
          👨‍🍳 Serve Customer ($<span id="serveMoney">1</span>)
        </button>
      </div>
      <p style="margin-top:10px; font-size:14px; color:#636e72;">Click pizza to make, then serve to customers!</p>
    </div>
  </div>

  <div class="upgrades">
    <h2>🛒 Upgrades</h2>
    
    <div class="upgrade-section">
      <h3>🧀 Ingredients (Increase Pizza Value)</h3>
      <div id="ingredientUpgrades"></div>
    </div>
    
    <div class="upgrade-section">
      <h3>🏭 Automation (Coins Per Second)</h3>
      <div id="automationUpgrades"></div>
    </div>
  </div>
</div>

<script>
// GAME STATE
let money = 0;
let pizzas = 0;
let pizzaValue = 1;
let cps = 0;

// INGREDIENTS
const ingredients = [
  {id: 'cheese', name: '🧀 Extra Cheese', cost: 50, value: 1, owned: false},
  {id: 'pepperoni', name: '🍖 Pepperoni', cost: 150, value: 2, owned: false},
  {id: 'mushroom', name: '🍄 Mushrooms', cost: 300, value: 3, owned: false},
  {id: 'olive', name: '🫒 Olives', cost: 600, value: 5, owned: false},
  {id: 'bacon', name: '🥓 Bacon', cost: 1200, value: 8, owned: false},
  {id: 'jalapeno', name: '🌶️ Jalapeños', cost: 2000, value: 10, owned: false},
  {id: 'garlic', name: '🧄 Garlic', cost: 3000, value: 12, owned: false},
  {id: 'spinach', name: '🥬 Spinach', cost: 4500, value: 15, owned: false},
  {id: 'tomato', name: '🍅 Sun-dried Tomatoes', cost: 6000, value: 18, owned: false},
  {id: 'corn', name: '🌽 Corn', cost: 8000, value: 22, owned: false},
  {id: 'truffle', name: '🍄‍🟫 Truffle', cost: 12000, value: 30, owned: false}
];

// AUTOMATION
const automation = [
  {id: 'oven1', name: '🔥 Basic Oven', cost: 100, cps: 1, count: 0},
  {id: 'oven2', name: '🔥🔥 Double Oven', cost: 500, cps: 5, count: 0},
  {id: 'chef1', name: '👨‍🍳 Chef', cost: 1000, cps: 10, count: 0},
  {id: 'chef2', name: '👨‍🍳👨‍🍳 Head Chef', cost: 3000, cps: 25, count: 0},
  {id: 'restaurant', name: '🏪 Restaurant', cost: 10000, cps: 100, count: 0}
];

// MAKE PIZZA
function makePizza() {
  pizzas++;
  updateUI();
}

// TOGGLE STATS
function toggleStats() {
  const statsContent = document.getElementById('statsContent');
  statsContent.classList.toggle('hidden');
}

// SERVE PIZZA
function servePizza() {
  if (pizzas <= 0) return;
  
  money += pizzaValue;
  pizzas--;
  updateUI();
}

// BUY INGREDIENT
function buyIngredient(id) {
  const ingredient = ingredients.find(i => i.id === id);
  if (!ingredient || ingredient.owned || money < ingredient.cost) return;
  
  money -= ingredient.cost;
  ingredient.owned = true;
  pizzaValue += ingredient.value;
  updateUI();
}

// BUY AUTOMATION
function buyAutomation(id) {
  const auto = automation.find(a => a.id === id);
  if (!auto || money < auto.cost) return;
  
  money -= auto.cost;
  auto.count++;
  auto.cost = Math.floor(auto.cost * 1.15); // Increase cost by 15%
  cps += auto.cps;
  updateUI();
}

// UPDATE UI
function updateUI() {
  document.getElementById('money').textContent = Math.floor(money);
  document.getElementById('pizzas').textContent = pizzas;
  document.getElementById('pizzaValue').textContent = pizzaValue;
  document.getElementById('cps').textContent = cps;
  document.getElementById('serveMoney').textContent = pizzaValue;
  
  // Enable/disable serve button
  document.getElementById('serveBtn').disabled = pizzas <= 0;
  
  renderUpgrades();
}

// RENDER UPGRADES
function renderUpgrades() {
  // Ingredients
  const ingredientDiv = document.getElementById('ingredientUpgrades');
  ingredientDiv.innerHTML = ingredients.map(ing => `
    <div class="upgrade-item ${ing.owned ? 'owned' : ''}">
      <div class="upgrade-info">
        <div class="upgrade-name">${ing.name} ${ing.owned ? '✓' : ''}</div>
        <div class="upgrade-desc">+$${ing.value} per pizza</div>
      </div>
      <button class="upgrade-btn" onclick="buyIngredient('${ing.id}')" 
        ${ing.owned || money < ing.cost ? 'disabled' : ''}>
        ${ing.owned ? 'Owned' : '$' + ing.cost}
      </button>
    </div>
  `).join('');
  
  // Automation
  const autoDiv = document.getElementById('automationUpgrades');
  autoDiv.innerHTML = automation.map(auto => `
    <div class="upgrade-item">
      <div class="upgrade-info">
        <div class="upgrade-name">${auto.name} (${auto.count})</div>
        <div class="upgrade-desc">+${auto.cps} CPS each</div>
      </div>
      <button class="upgrade-btn" onclick="buyAutomation('${auto.id}')" 
        ${money < auto.cost ? 'disabled' : ''}>
        $${auto.cost}
      </button>
    </div>
  `).join('');
}

// CPS LOOP
setInterval(() => {
  if (cps > 0) {
    money += cps / 10; // Divide by 10 because we're running every 100ms
    updateUI();
  }
}, 100);

// INIT
updateUI();
</script>

</body>
</html>
